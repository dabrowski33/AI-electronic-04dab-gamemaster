# GenRL GameMaster AI - Environment Variables
# Copy to .env and fill in your values

# Database
POSTGRES_PASSWORD=genrl_secure_pass

# OpenRouter API (for Hermes 3)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API (for Codex fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Java Simulator Service
JAVA_SIMULATOR_PORT=8080

# Python Orchestrator Service
PYTHON_ORCHESTRATOR_PORT=8000

# Node.js BFF Gateway
NODE_BFF_PORT=3000

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# OpenCode Sandbox (optional - for local execution)
OPENCODE_TIMEOUT_SECONDS=60
OPENCODE_MEMORY_LIMIT_MB=512
OPENCODE_CPU_LIMIT=1.0